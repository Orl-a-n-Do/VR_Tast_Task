  m_text: "\u041F\u0440\u0435\u0434\u044B\u0441\u0442\u043E\u0440\u0438\u044F:\n\u0421\u0442\u0440\u0430\u043D\u0430
    \u041C - \u043B\u0438\u0434\u0435\u0440 \u043F\u043E \u044D\u043A\u0441\u043F\u043E\u0440\u0442\u0443
    \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432. \u041D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435
    \u0438\u043D\u0432\u0435\u0441\u0442\u043E\u0440\u043E\u0432 \u0437\u0430\u0447\u0430\u0441\u0442\u0443\u044E
    \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0439. \u0412 \u043A\u0440\u0438\u0437\u0438\u0441\u043D\u044B\u0435
    \u043C\u043E\u043C\u0435\u043D\u0442\u044B \u043F\u043E\u0442\u0440\u0435\u0431\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u043A\u043E\u0440\u0437\u0438\u043D\u0430 \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u0430
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0442\u043E\u0432\u0430\u0440\u043E\u0432
    \u043F\u0435\u0440\u0432\u043E\u0439 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438."
